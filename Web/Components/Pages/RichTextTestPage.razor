@page "/rich-text-editor"

@rendermode RenderMode.InteractiveServer 

@using BlazorUI.Components.Inputs.RichTextInput.Classes

<section style="padding: 1.5rem 2rem; height: 80vh; display: flex; justify-content: center; align-items: center; gap: 3rem; flex-wrap: wrap;">
    <div>
        <RichTextInput @bind-Value=@falobjRichTextValue Placeholder="Start typing here..." />
    </div>
    <div class="rich-text__output" style="max-width: 500px; width: 100%; min-height: 400px;">
        <h3 style="color: #444; padding-bottom: 1rem;">Preview:</h3>
        @RichTextInput.fncRenderContent(falobjRichTextValue)
    </div>
</section>

