    //     {
    //         fstrMessage = "You cancelled the modal!";
    //     }

    //     StateHasChanged();
    }

    #region cookie test
    struct structTestCookieValue
    {
        public System.String mstrUserName { get; set; }
        public System.Int32 mintFavoriteGroupID { get; set; }
    }
    private structTestCookieValue msruTestCookieValue = new();

    private async void subTestSetCookie()
    {
        try
        {
            structTestCookieValue sruTestCookieValue = new structTestCookieValue
                {
                    mstrUserName = "user.name",
                    mintFavoriteGroupID = 20,
                };

            await subSetCookieAsync("testCookie", sruTestCookieValue);

            msruTestCookieValue = await fncGetCookieAsync<structTestCookieValue>("testCookie");
            StateHasChanged();
        }
        catch (System.Exception ex)
        {
            subSetLastError(System.Reflection.MethodBase.GetCurrentMethod().Name, ex.Message);
        }
    }

    private async void subTestDeleteCookie()
    {
        try
        {

            await subDeleteCookieAsync("testCookie");
            msruTestCookieValue = new structTestCookieValue();
        }
        catch (System.Exception ex)
        {
            subSetLastError(System.Reflection.MethodBase.GetCurrentMethod().Name, ex.Message);
        }
    }
    #endregion
}
