@inherits cErrorFunctions
@typeparam TData

@* Responsible for registering columns and column display names for the table *@

@code {
    #region Class Declarations
    [CascadingParameter(Name = "Columns")] private System.Collections.Generic.List<cColumn<TData>> malobjColumns { get; set; }
    /// <summary>
    /// The name of the field (i.e. @(column => column.mstrField))
    /// </summary>
    [Parameter, EditorRequired] public System.Linq.Expressions.Expression<System.Func<TData, System.Object>> Field { get; set; }
    /// <summary>
    /// The Display Text for the column's heading
    /// </summary>
    [Parameter] public System.String DisplayName { get; set; } = System.String.Empty;
    /// <summary>
    /// Hide column
    /// </summary>
    [Parameter] public System.Boolean Hidden { get; set; } = false;
    /// <summary>
    /// The column's text alignment
    /// </summary>
    [Parameter] public enumTextAlign TextAlign { get; set; } = enumTextAlign.typLeft;
    /// <summary>
    /// Initial column width in pixels, defaults to min-width
    /// </summary>
    [Parameter] public System.Int32? DefaultWidth { get; set; } = null;
    [Parameter] public RenderFragment<TData>? ChildContent { get; set; }
    #endregion

    #region OnInitialized
    protected override void OnInitialized()
    {
        try
        {
            System.String strFieldName = subGetPropertyName(Field);

            cColumn<TData> objColumn = new cColumn<TData>(enumColumnType.typData, strFieldName, DisplayName, Hidden, TextAlign, DefaultWidth, ChildContent);

            malobjColumns.Add(objColumn);
        }
        catch (System.Exception ex)
        {
            subSetLastError(System.Reflection.MethodBase.GetCurrentMethod().Name, ex.Message);
        }
    }
    #endregion

    #region fncGetPropertyName
    private static System.String subGetPropertyName<T>(System.Linq.Expressions.Expression<System.Func<T, System.Object>> pfncPropertyExpression)
    {
        if (pfncPropertyExpression.Body is System.Linq.Expressions.UnaryExpression objUnaryExpression && objUnaryExpression.Operand is System.Linq.Expressions.MemberExpression objMemberExpression)
        {
            return objMemberExpression.Member.Name;
        }
        else if (pfncPropertyExpression.Body is System.Linq.Expressions.MemberExpression objBodyMemberExpression)
        {
            return objBodyMemberExpression.Member.Name;
        }

        throw new System.InvalidOperationException("Invalid property expression");
    }
    #endregion
}
